# Database (use a hosted Postgres - Render, Railway, or Neon all have free tiers)
DATABASE_URL="postgresql://username:password@host:port/database?schema=public"

PORT=5000

# Generate a real random secret for production, e.g.: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-string"

# Admin account created by `npm run seed` - pick your own values, do not commit real ones
ADMIN_USERNAME="your-admin-username"
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD="choose-a-strong-password"

# Used by the contact form to email you new messages (optional - leave blank to disable)
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_USER="your@email.com"
EMAIL_PASS="your-email-app-password"
CONTACT_RECEIVER="work.naciri@gmail.com"

# The deployed frontend URL, for CORS. Use http://localhost:5173 in dev.
FRONTEND_URL="https://your-portfolio.vercel.app"

# Set to "production" when deployed (controls cookie security flags)
NODE_ENV="development"
